# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Service role key (SOLO servidor, nunca expongas con NEXT_PUBLIC_).
# Necesaria para gestionar/invitar usuarios desde /admin/usuarios.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL pública del sitio (sitemap, robots, OG, enlaces de invitación).
NEXT_PUBLIC_SITE_URL=https://carpaslopez.cl

# Notificación de leads por email (opcional). Sin estas claves el lead igual se guarda.
RESEND_API_KEY=
LEADS_FROM=Carpas López <onboarding@resend.dev>
